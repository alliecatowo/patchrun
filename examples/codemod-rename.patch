diff --git a/api/services.py b/api/services.py
index 1a2b3c4..5d6e7f8 100644
--- a/api/services.py
+++ b/api/services.py
@@ -1,15 +1,18 @@
 from typing import Optional

-class UserSvc:
+class UserService:
     def __init__(self, db):
         self.db = db

-    async def fetch(self, user_id: str) -> Optional[dict]:
+    async def fetch_one(self, user_id: str) -> Optional[dict]:
         row = await self.db.fetchrow("SELECT * FROM users WHERE id = $1", user_id)
         return dict(row) if row else None

-    async def fetch_all(self) -> list[dict]:
-        rows = await self.db.fetch("SELECT * FROM users")
+    async def fetch_all(self, limit: Optional[int] = None) -> list[dict]:
+        if limit is not None:
+            rows = await self.db.fetch("SELECT * FROM users LIMIT $1", int(limit))
+        else:
+            rows = await self.db.fetch("SELECT * FROM users")
         return [dict(r) for r in rows]
